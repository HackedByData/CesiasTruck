---
/**
 * DishCard — a photo-forward menu card: optimized image, name, price,
 * description, an optional badge (top-left) and an optional action slot
 * (e.g. an add-to-order Button). Lifts and zooms the photo on hover.
 */
import { Image } from 'astro:assets';
interface Props {
  image: ImageMetadata;
  alt?: string;
  name: string;
  price: string;
  description?: string;
  /* Optional bilingual description — the island swaps these in place. */
  descEn?: string;
  descEs?: string;
  class?: string;
}
const { image, alt = '', name, price, description, descEn, descEs, class: cls = '' } = Astro.props;
const hasBadge = Astro.slots.has('badge');
const hasAction = Astro.slots.has('action');
---
<article class:list={['dish-card', cls]}>
  <div class="dish-card__media">
    <Image src={image} alt={alt} widths={[320, 520, 760]} sizes="(min-width: 880px) 33vw, 90vw" />
    {hasBadge && <div class="dish-card__badge"><slot name="badge" /></div>}
  </div>
  <div class="dish-card__body">
    <div class="dish-card__head">
      <h3 class="dish-card__name">{name}</h3>
      <span class="dish-card__price">{price}</span>
    </div>
    {description && <p class="dish-card__desc" data-en={descEn} data-es={descEs}>{description}</p>}
    {hasAction && <div class="dish-card__action"><slot name="action" /></div>}
  </div>
</article>
