---
import { Image } from 'astro:assets';
import { ui, catering } from '../../data/content.js';
import { images } from '../../data/images.js';
import SectionHeading from '../ui/SectionHeading.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
const en = ui.en;
---
<section class="section section--sand" id="catering">
  <div class="container">
    <div class="section__head">
      <SectionHeading eyebrowKey="cater.eyebrow" titleKey="cater.title" />
      <p class="section__sub" data-i18n="cater.sub">{en['cater.sub']}</p>
    </div>

    <div class="cater-grid">
      {
        catering.map((c) => (
          <article class="cc">
            <div class="cc__media">
              <Image
                src={images[c.key as keyof typeof images]}
                alt={c.name}
                widths={[300, 500, 700]}
                sizes="(min-width: 560px) 33vw, 90vw"
                loading="lazy"
              />
              <span class="cc__price">{c.price}</span>
            </div>
            <div class="cc__body">
              <h3 class="cc__title">{c.name}</h3>
              <p class="cc__desc" data-en={c.desc.en} data-es={c.desc.es}>
                {c.desc.en}
              </p>
            </div>
          </article>
        ))
      }
    </div>

    <div class="cater-cta">
      <Button variant="accent" size="md" href="tel:+17147106159">
        <Icon name="phone" size={18} slot="icon-left" />
        <span data-i18n="cater.call">{en['cater.call']}</span>
      </Button>
    </div>
  </div>
</section>
