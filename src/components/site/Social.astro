---
import { ui, site } from '../../data/content.js';
import SectionHeading from '../ui/SectionHeading.astro';
const en = ui.en;
const { instagram, tiktok, yelp } = site.social;
---
<section class="section section--raised" id="social" style="text-align: center">
  <div class="container">
    <div class="section__head">
      <SectionHeading eyebrowKey="social.eyebrow" titleKey="social.title" />
    </div>
    <div class="social-list">
      <a class="soc" href={instagram.url} target="_blank" rel="noopener" aria-label={`Instagram ${instagram.handle}`}>
        <span class="soc__icon soc--ig" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17.5" cy="6.5" r="1.1" fill="currentColor" stroke="none"></circle>
          </svg>
        </span>
        <span class="soc__text"><b>Instagram</b><span>{instagram.handle}</span></span>
      </a>

      <a class="soc" href={tiktok.url} target="_blank" rel="noopener" aria-label={`TikTok ${tiktok.handle}`}>
        <span class="soc__icon soc--tt" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M16.5 3c.3 2.1 1.5 3.6 3.5 3.9v2.4c-1.3.1-2.5-.2-3.6-.8v5.9c0 3.3-2.4 5.6-5.5 5.6-3 0-5.3-2.2-5.3-5.1 0-3 2.4-5.2 5.6-4.9v2.5c-.4-.1-.9-.2-1.3-.1-1.3.2-2.2 1.2-2.1 2.6.1 1.3 1.2 2.3 2.5 2.2 1.4 0 2.3-1 2.3-2.6V3z"></path>
          </svg>
        </span>
        <span class="soc__text"><b>TikTok</b><span>{tiktok.handle}</span></span>
      </a>

      <a class="soc" href={yelp.url} target="_blank" rel="noopener" aria-label="Yelp — Cesia's Truck">
        <span class="soc__icon soc--yelp" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path d="M11 3.5c0-.8.6-1.4 1.4-1.2 1.4.3 3 .9 3.8 1.5.6.5.5 1.2-.1 1.7l-3.7 3c-.7.6-1.4.2-1.4-.7zm-1 7.3c.5.6.2 1.4-.6 1.5L5 13c-.8.1-1.4-.5-1.2-1.3.3-1.4 1-2.9 1.6-3.7.5-.6 1.2-.5 1.7.2zm1.5 2.6c.7-.4 1.5.1 1.4.9l-.4 4.5c-.1.8-.9 1.2-1.5.6-1-.9-2-2.2-2.4-3.1-.3-.7.1-1.3.9-1.4zm4.6.5c-.7-.3-.8-1.2-.1-1.6l3.9-2.3c.7-.4 1.5 0 1.5.9 0 1.4-.4 3-.8 3.9-.3.7-1.1.8-1.6.2zm-.2 1.9c.6-.5 1.4-.2 1.5.6.2 1 .2 2.4.1 3.3-.1.8-.9 1.1-1.5.6-.8-.8-1.7-2-2.1-2.8z"></path>
          </svg>
        </span>
        <span class="soc__text"><b>Yelp</b><span data-i18n="social.yelp">{en['social.yelp']}</span></span>
      </a>
    </div>
  </div>
</section>
