---
/* Right-side order drawer. The line items, totals, pickup chips and
   send-by-text button are rendered into #sheet-body / #sheet-foot by the
   client island; the header "Order" button opens it. */
import { ui } from '../../data/content.js';
import Icon from '../ui/Icon.astro';
const en = ui.en;
---
<div class="sheet-scrim" id="scrim" data-act="close-sheet"></div>

<aside class="sheet" id="sheet" role="dialog" aria-modal="true" aria-hidden="true" aria-labelledby="sheet-title">
  <div class="sheet__head">
    <h2 class="sheet__title" id="sheet-title" data-i18n="order.title">{en['order.title']}</h2>
    <button class="sheet__close" id="sheet-close" type="button" data-act="close-sheet" aria-label="Close">
      <Icon name="x" />
    </button>
  </div>
  <div class="sheet__body" id="sheet-body"></div>
  <div class="sheet__foot" id="sheet-foot"></div>
</aside>
