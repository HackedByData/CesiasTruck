---
import BaseLayout from '../layouts/BaseLayout.astro';
import { images } from '../data/images.js';
import Button from '../components/ui/Button.astro';
import Badge from '../components/ui/Badge.astro';
import MenuRow from '../components/ui/MenuRow.astro';
import DishCard from '../components/ui/DishCard.astro';
import LangToggle from '../components/ui/LangToggle.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import Input from '../components/ui/Input.astro';
import Icon from '../components/ui/Icon.astro';

const colorScales = [
  { name: 'Marigold', note: 'Primary brand — the logo halo', stops: ['50', '100', '200', '300', '400', '500', '600', '700'], prefix: 'marigold', core: '400' },
  { name: 'Chalkboard', note: 'The menu board & the truck body', stops: ['900', '800', '700', '600', '500', '400', '300'], prefix: 'char', core: '800' },
  { name: 'Lime', note: 'Menu names, cilantro, fresh', stops: ['100', '200', '300', '400', '500', '600'], prefix: 'lime', core: '400' },
  { name: 'Chile', note: 'Salsa roja, consomé, heat — the red', stops: ['100', '300', '400', '500', '600', '700'], prefix: 'chile', core: '500' },
  { name: 'Tortilla', note: 'Warm cream paper neutrals', stops: ['50', '100', '200', '300', '400', '500', '600', '700'], prefix: 'tortilla', core: '100' },
  { name: 'Radish', note: 'Rare pop accent', stops: ['400', '500'], prefix: 'radish', core: '500' },
];

const semantic = [
  ['--brand', 'Primary action / highlight'],
  ['--accent', 'Salsa-red call-to-action'],
  ['--accent-fresh', 'Fresh / vegetarian'],
  ['--surface-page', 'Cream page'],
  ['--surface-board', 'Chalkboard'],
  ['--text-board-name', 'Menu item name'],
  ['--text-board-price', 'Menu price'],
];

const typeScale = [
  ['--text-hero', 'Hero', 'clamp(3rem, 8vw, 6.5rem)'],
  ['--text-display', 'Display', 'clamp(2.4rem, 5.5vw, 4.25rem)'],
  ['--text-h1', 'H1', 'clamp(2rem, 4vw, 3rem)'],
  ['--text-h2', 'H2', 'clamp(1.6rem, 3vw, 2.25rem)'],
  ['--text-lg', 'Body large', '1.175rem'],
  ['--text-base', 'Body', '1rem'],
];

const spaceStops = ['1', '2', '3', '4', '5', '6', '7', '8'];
const spacePx = { '1': '4', '2': '8', '3': '12', '4': '16', '5': '24', '6': '32', '7': '48', '8': '64' };
const radii = ['sm', 'md', 'lg', 'xl', 'pill'];
const shadows = ['sm', 'md', 'lg', 'board', 'brand'];
---
<BaseLayout title="Cesia’s Truck — Design System">
  <header class="ds-top">
    <div class="ds-wrap ds-top__bar">
      <span class="ds-top__brand script">Cesia’s Truck</span>
      <span class="ds-top__label">Design System</span>
      <a class="ds-top__back" href="/">← Back to site</a>
    </div>
  </header>

  <main id="main">
    <section class="ds-hero">
      <div class="ds-wrap">
        <span class="eyebrow ds-hero__eyebrow">The system behind the truck</span>
        <h1 class="display ds-hero__title">Cesia’s Truck<br />Design System</h1>
        <p class="ds-hero__sub">
          Marigold + chalkboard-black + lime + chile-red, pulled straight off the truck’s
          menu board. Anton display, Yellowtail script, Barlow body. Every token, component
          and rule the site is built from.
        </p>
      </div>
    </section>

    <!-- ============ COLOR ============ -->
    <section class="ds-section ds-wrap" id="color">
      <h2 class="ds-h2 display">Color</h2>
      <div class="ds-grid">
        {
          colorScales.map((scale) => (
            <article class="ds-card">
              <div class="ds-card__meta">
                <span class="ds-card__name">{scale.name}</span>
                <span class="ds-card__note">{scale.note}</span>
              </div>
              <div class="ds-swatches">
                {scale.stops.map((s) => (
                  <div class="ds-swatch">
                    <span class="ds-swatch__chip" style={`background: var(--${scale.prefix}-${s})`} data-core={s === scale.core ? 'true' : 'false'} />
                    <span class="ds-swatch__num">{s}</span>
                  </div>
                ))}
              </div>
            </article>
          ))
        }
        <article class="ds-card ds-card--wide">
          <div class="ds-card__meta">
            <span class="ds-card__name">Semantic roles</span>
            <span class="ds-card__note">Reach for these in components</span>
          </div>
          <div class="ds-semantic">
            {
              semantic.map(([token, label]) => (
                <div class="ds-semantic__row">
                  <span class="ds-semantic__chip" style={`background: var(${token})`} />
                  <code class="ds-semantic__token">{token}</code>
                  <span class="ds-semantic__label">{label}</span>
                </div>
              ))
            }
          </div>
        </article>
      </div>
    </section>

    <!-- ============ TYPE ============ -->
    <section class="ds-section ds-wrap" id="type">
      <h2 class="ds-h2 display">Type</h2>
      <div class="ds-grid">
        <article class="ds-card">
          <div class="ds-card__meta"><span class="ds-card__name">Anton — Display</span><span class="ds-card__note">The truck’s shout</span></div>
          <div class="ds-spec" style="font-family: var(--font-display); font-size: 56px; text-transform: uppercase; line-height: 0.9; color: var(--text-strong)">Quesatacos</div>
        </article>
        <article class="ds-card">
          <div class="ds-card__meta"><span class="ds-card__name">Yellowtail — Script</span><span class="ds-card__note">The family signature</span></div>
          <div class="ds-spec" style="font-family: var(--font-script); font-size: 48px; color: var(--accent)">your favorite taco</div>
        </article>
        <article class="ds-card">
          <div class="ds-card__meta"><span class="ds-card__name">Barlow — Body</span><span class="ds-card__note">Everything you read</span></div>
          <p class="ds-spec" style="font-size: 17px; line-height: 1.55; color: var(--text-body); margin: 0">Slow-cooked birria, crispy quesatacos, and consomé to dip — made fresh on the truck every single day in Irvine.</p>
        </article>
        <article class="ds-card">
          <div class="ds-card__meta"><span class="ds-card__name">Barlow Condensed — Menu</span><span class="ds-card__note">Rows, labels, prices</span></div>
          <div class="ds-spec">
            <MenuRow name="Quesatacos" price="$3.75" />
          </div>
        </article>
        <article class="ds-card ds-card--wide">
          <div class="ds-card__meta"><span class="ds-card__name">Type scale</span><span class="ds-card__note">Fluid display sizes</span></div>
          <div class="ds-scale">
            {
              typeScale.map(([token, , val]) => (
                <div class="ds-scale__row">
                  <span class="ds-scale__sample display" style={`font-size: ${token.includes('hero') || token.includes('display') ? 'clamp(1.5rem, 5vw, 2.6rem)' : '1.4rem'}`}>Birria</span>
                  <code class="ds-scale__token">{token}</code>
                  <span class="ds-scale__val">{val}</span>
                </div>
              ))
            }
          </div>
        </article>
      </div>
    </section>

    <!-- ============ SPACING / RADIUS / SHADOW ============ -->
    <section class="ds-section ds-wrap" id="spacing">
      <h2 class="ds-h2 display">Spacing · Radius · Shadow</h2>
      <div class="ds-grid">
        <article class="ds-card ds-card--wide">
          <div class="ds-card__meta"><span class="ds-card__name">Spacing scale</span><span class="ds-card__note">4px base</span></div>
          <div class="ds-space">
            {
              spaceStops.map((s) => (
                <div class="ds-space__row">
                  <span class="ds-space__bar" style={`width: var(--space-${s})`} />
                  <code class="ds-space__token">--space-{s}</code>
                  <span class="ds-space__val">{spacePx[s as keyof typeof spacePx]}px</span>
                </div>
              ))
            }
          </div>
        </article>
        <article class="ds-card">
          <div class="ds-card__meta"><span class="ds-card__name">Radii</span><span class="ds-card__note">Hand-cut, not bubbly</span></div>
          <div class="ds-radii">
            {radii.map((r) => (
              <div class="ds-radii__item">
                <span class="ds-radii__box" style={`border-radius: var(--radius-${r})`} />
                <code>{r}</code>
              </div>
            ))}
          </div>
        </article>
        <article class="ds-card">
          <div class="ds-card__meta"><span class="ds-card__name">Shadows</span><span class="ds-card__note">Warm, soft — sun on the truck</span></div>
          <div class="ds-shadows">
            {shadows.map((s) => (
              <div class="ds-shadows__item">
                <span class="ds-shadows__box" style={`box-shadow: var(--shadow-${s})`} />
                <code>{s}</code>
              </div>
            ))}
          </div>
        </article>
      </div>
    </section>

    <!-- ============ COMPONENTS ============ -->
    <section class="ds-section ds-wrap" id="components">
      <h2 class="ds-h2 display">Components</h2>

      <div class="ds-grid">
        <!-- Buttons -->
        <article class="ds-card ds-card--wide">
          <div class="ds-card__meta"><span class="ds-card__name">Button</span><span class="ds-card__note">primary · accent · secondary · ghost · sizes · states</span></div>
          <div class="ds-row">
            <Button variant="primary">Primary</Button>
            <Button variant="accent">Accent</Button>
            <Button variant="secondary">Secondary</Button>
            <Button variant="ghost">Ghost</Button>
            <Button variant="primary" disabled>Disabled</Button>
          </div>
          <div class="ds-row">
            <Button variant="accent" size="sm">Small</Button>
            <Button variant="accent" size="md">Medium</Button>
            <Button variant="accent" size="lg">Large</Button>
            <Button variant="primary" size="md"><Icon name="bag" size={16} slot="icon-left" />With icon</Button>
            <Button variant="primary" size="md"><Icon name="arrow" size={16} slot="icon-right" />Next</Button>
          </div>
          <div class="ds-row ds-row--board">
            <Button variant="primary" onBoard>Primary</Button>
            <Button variant="secondary" onBoard>Secondary</Button>
            <Button variant="ghost" onBoard>Ghost</Button>
            <Button variant="outline" onBoard>Outline</Button>
          </div>
        </article>

        <!-- Badges -->
        <article class="ds-card">
          <div class="ds-card__meta"><span class="ds-card__name">Badge</span><span class="ds-card__note">soft + solid tones</span></div>
          <div class="ds-row ds-row--wrap">
            <Badge tone="marigold">Especial</Badge>
            <Badge tone="chile" solid>Spicy</Badge>
            <Badge tone="lime">Veggie</Badge>
            <Badge tone="char">Keto</Badge>
          </div>
          <div class="ds-row ds-row--wrap">
            <Badge tone="marigold" solid>Especial</Badge>
            <Badge tone="chile">Spicy</Badge>
            <Badge tone="lime" solid>Veggie</Badge>
            <Badge tone="char" solid>Keto</Badge>
          </div>
        </article>

        <!-- LangToggle -->
        <article class="ds-card">
          <div class="ds-card__meta"><span class="ds-card__name">LangToggle</span><span class="ds-card__note">light + on board</span></div>
          <div class="ds-row">
            <LangToggle />
          </div>
          <div class="ds-row ds-row--board">
            <LangToggle onBoard />
          </div>
        </article>

        <!-- MenuRow light -->
        <article class="ds-card">
          <div class="ds-card__meta"><span class="ds-card__name">MenuRow — paper</span><span class="ds-card__note">salsa-red price, dotted leader</span></div>
          <div class="ds-spec">
            <MenuRow name="Quesatacos" price="$3.75">
              <Badge slot="badge" tone="chile" solid>Spicy</Badge>
              <span slot="note" class="menu-row__note">Crispy birria taco with melted cheese and consomé to dip.</span>
            </MenuRow>
            <MenuRow name="Mulita" price="$3.75">
              <span slot="note" class="menu-row__note">Two tortillas, double cheese, birria pressed inside.</span>
            </MenuRow>
          </div>
        </article>

        <!-- MenuRow board -->
        <article class="ds-card">
          <div class="ds-card__meta"><span class="ds-card__name">MenuRow — chalkboard</span><span class="ds-card__note">lime name, gold price</span></div>
          <div class="ds-spec ds-spec--board">
            <MenuRow name="Birria Pizza" price="$22.00" onBoard>
              <Badge slot="badge" tone="marigold" solid>Especial</Badge>
              <span slot="note" class="menu-row__note">A whole birria quesadilla, cut like a pizza.</span>
            </MenuRow>
            <MenuRow name="Mamalona" price="$36.00" onBoard>
              <span slot="note" class="menu-row__note">The big one. A spread of birria to share.</span>
            </MenuRow>
          </div>
        </article>

        <!-- SectionHeading -->
        <article class="ds-card">
          <div class="ds-card__meta"><span class="ds-card__name">SectionHeading</span><span class="ds-card__note">eyebrow · script · title</span></div>
          <div class="ds-spec">
            <SectionHeading eyebrowKey="menu.eyebrow" scriptKey="loc.script" titleKey="menu.title" align="left" />
          </div>
        </article>

        <!-- DishCard -->
        <article class="ds-card">
          <div class="ds-card__meta"><span class="ds-card__name">DishCard</span><span class="ds-card__note">photo · name · price · action</span></div>
          <div class="ds-spec">
            <DishCard
              image={images.quesatacos}
              alt="Quesatacos"
              name="Quesatacos"
              price="$3.75"
              description="Crispy birria taco with melted cheese and consomé to dip."
            >
              <Badge slot="badge" tone="chile" solid>Spicy</Badge>
              <Button slot="action" variant="primary" size="sm" block>Add to order</Button>
            </DishCard>
          </div>
        </article>

        <!-- Input -->
        <article class="ds-card">
          <div class="ds-card__meta"><span class="ds-card__name">Input</span><span class="ds-card__note">label · field · hint · error</span></div>
          <div class="ds-spec ds-stack">
            <Input label="Name" placeholder="Your name" />
            <Input label="Notes" as="textarea" placeholder="No onions, extra consomé…" hint="Tell us how you like it." />
            <Input label="Phone" placeholder="(714) 000-0000" error="Enter a valid phone number." />
          </div>
        </article>
      </div>
    </section>

    <footer class="ds-foot">
      <div class="ds-wrap">
        <span class="script">¡Buen provecho!</span>
        <a href="/">← Back to the truck</a>
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  .ds-wrap { width: 100%; max-width: 1080px; margin-inline: auto; padding-inline: 20px; }

  .ds-top { position: sticky; top: 0; z-index: 50; background: rgba(21, 17, 13, 0.96); backdrop-filter: blur(10px); border-bottom: 2px solid var(--brand); }
  .ds-top__bar { display: flex; align-items: center; gap: 14px; height: 60px; }
  .ds-top__brand { color: var(--brand); font-size: 24px; line-height: 1; padding-top: 4px; }
  .ds-top__label { font-family: var(--font-menu); font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; font-size: 12px; color: var(--tortilla-300); padding: 4px 10px; border: 1px solid var(--char-500); border-radius: var(--radius-pill); }
  .ds-top__back { margin-left: auto; font-family: var(--font-menu); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; font-size: 13px; color: var(--marigold-300); }
  .ds-top__back:hover { color: var(--brand); }

  .ds-hero { background: var(--surface-board); color: var(--tortilla-100); padding: 64px 0 56px; border-bottom: 4px solid var(--accent); }
  .ds-hero__eyebrow { color: var(--marigold-300); }
  .ds-hero__title { font-size: clamp(40px, 8vw, 76px); color: #fff; margin: 8px 0 18px; }
  .ds-hero__sub { max-width: 56ch; color: var(--tortilla-300); font-size: 18px; line-height: 1.6; }

  .ds-section { padding: 54px 20px; }
  .ds-h2 { font-size: clamp(30px, 6vw, 44px); color: var(--text-strong); margin: 0 0 24px; padding-bottom: 12px; border-bottom: 3px solid var(--brand); }

  .ds-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 18px; }
  .ds-card { background: var(--surface-card); border: 1px solid var(--border-soft); border-radius: var(--radius-lg); padding: 20px; box-shadow: var(--shadow-sm); }
  .ds-card--wide { grid-column: 1 / -1; }
  .ds-card__meta { display: flex; flex-direction: column; gap: 2px; margin-bottom: 16px; }
  .ds-card__name { font-family: var(--font-menu); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; font-size: 15px; color: var(--text-strong); }
  .ds-card__note { font-size: 13px; color: var(--text-muted); }

  .ds-swatches { display: flex; flex-wrap: wrap; gap: 8px; }
  .ds-swatch { display: flex; flex-direction: column; align-items: center; gap: 5px; }
  .ds-swatch__chip { width: 46px; height: 46px; border-radius: var(--radius-sm); border: 1px solid rgba(0, 0, 0, 0.08); display: block; }
  .ds-swatch__chip[data-core='true'] { outline: 2px solid var(--char-900); outline-offset: 2px; }
  .ds-swatch__num { font-family: var(--font-menu); font-size: 12px; font-weight: 600; color: var(--text-muted); }

  .ds-semantic { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 10px; }
  .ds-semantic__row { display: flex; align-items: center; gap: 10px; }
  .ds-semantic__chip { width: 30px; height: 30px; border-radius: var(--radius-sm); border: 1px solid rgba(0, 0, 0, 0.1); flex: none; }
  .ds-semantic__token { font-family: var(--font-menu); font-size: 13px; color: var(--text-strong); font-weight: 600; }
  .ds-semantic__label { font-size: 12.5px; color: var(--text-muted); }

  .ds-spec { padding: 4px 2px; }
  .ds-spec--board { background: var(--surface-board); border-radius: var(--radius-md); padding: 14px 18px; }
  .ds-stack { display: flex; flex-direction: column; gap: 14px; }

  .ds-scale__row { display: grid; grid-template-columns: 1fr auto auto; align-items: center; gap: 14px; padding: 8px 0; border-bottom: 1px solid var(--border-soft); }
  .ds-scale__token { font-family: var(--font-menu); font-size: 13px; color: var(--accent); font-weight: 700; }
  .ds-scale__val { font-size: 12.5px; color: var(--text-muted); font-variant-numeric: tabular-nums; }

  .ds-space__row { display: grid; grid-template-columns: 120px auto 1fr; align-items: center; gap: 14px; padding: 6px 0; }
  .ds-space__bar { height: 16px; background: var(--brand); border-radius: 3px; display: block; }
  .ds-space__token { font-family: var(--font-menu); font-size: 13px; color: var(--text-strong); font-weight: 600; }
  .ds-space__val { font-size: 12.5px; color: var(--text-muted); }

  .ds-radii, .ds-shadows { display: flex; flex-wrap: wrap; gap: 18px; }
  .ds-radii__item, .ds-shadows__item { display: flex; flex-direction: column; align-items: center; gap: 8px; }
  .ds-radii__box { width: 64px; height: 48px; background: var(--marigold-200); border: 2px solid var(--brand); }
  .ds-shadows__box { width: 64px; height: 48px; background: var(--surface-card); border-radius: var(--radius-md); }
  .ds-radii code, .ds-shadows code { font-family: var(--font-menu); font-size: 12px; color: var(--text-muted); }

  .ds-row { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; margin-bottom: 12px; }
  .ds-row--wrap { gap: 8px; }
  .ds-row--board { background: var(--surface-board); border-radius: var(--radius-md); padding: 16px; margin-top: 4px; }
  .ds-row:last-child { margin-bottom: 0; }

  .ds-foot { background: var(--surface-board); color: var(--tortilla-300); padding: 36px 20px; text-align: center; }
  .ds-foot .script { color: var(--brand); font-size: 30px; display: block; margin-bottom: 8px; }
  .ds-foot a { font-family: var(--font-menu); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; font-size: 13px; color: var(--marigold-300); }

  @media (max-width: 520px) {
    .ds-scale__row { grid-template-columns: 1fr auto; }
    .ds-scale__val { display: none; }
  }
</style>
